      "note": "metric-based only; GLM probe blocked"
    },
    {
      "id": "tt-rebuild",
      "alert": "MarkhandDriftDetected",
      "runbook": "docs/runbooks/vector-rebuild.md",
      "stages_ordered": [
        "detection",
        "contain",
        "recover",
        "verify",
        "rollback"
      ],
      "outcome": "pass_tabletop",
      "promtool_case": "drift_detected_fires"
    },
    {
      "id": "tt-key-rotation",
      "alert": "MarkhandAuthDenySpike",
      "runbook": "docs/runbooks/key-rotation.md",
      "stages_ordered": [
        "detection",
        "contain",
        "recover",
        "verify",
        "rollback"
      ],
      "outcome": "pass_tabletop",
      "promtool_case": "auth_deny_count_threshold"
    },
    {
      "id": "tt-search-availability",
      "alert": "MarkhandSearchAvailabilityBurn",
      "runbook": "docs/runbooks/dependency-outage.md",
      "stages_ordered": [
        "detection",
        "contain",
        "recover",
        "verify",
        "rollback"
      ],
      "outcome": "pass_tabletop",
      "promtool_case": "search_availability_5xx_only_fires_and_resolves"

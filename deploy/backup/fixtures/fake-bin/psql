#!/usr/bin/env bash
# Stateful fake psql for readiness campaign helpers.
set -euo pipefail
if [[ "${MARKHAND_FAKE_PSQL_FAIL:-0}" == "1" ]]; then
  echo "ERROR: fake psql failure" >&2
  exit 1
fi

STATE_DIR="${MARKHAND_FAKE_PSQL_STATE:-${TMPDIR:-/tmp}/markhand-fake-psql-state}"
mkdir -p "$STATE_DIR"
STATE="$STATE_DIR/readiness.state"
if [[ ! -f "$STATE" ]]; then
  cat >"$STATE" <<'EOF'
generation=0
ready=false
completed=0
drift=0
error=0
last_result=
last_drift=-1
zero_drift=false
expected=0
terminal=0
sealed=false
unresolved=0
EOF
fi
# shellcheck disable=SC1090
source "$STATE"

sql=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) sql="$2"; shift 2 ;;
    -v) shift 2 ;;
    -At|-A|-t|-q|-X) shift ;;
    -h|-p|-U|-d) shift 2 ;;
    *) shift ;;
  esac
done

persist() {
  cat >"$STATE" <<EOF
generation=$generation
ready=$ready
completed=$completed
drift=$drift
error=$error
last_result=$last_result
last_drift=$last_drift
zero_drift=$zero_drift
expected=$expected
terminal=$terminal
sealed=$sealed
unresolved=$unresolved
EOF
}

if [[ -z "$sql" ]]; then
  printf '%s\n' "${MARKHAND_FAKE_PG_TIMELINE:-1}"
  printf '%s\n' "${MARKHAND_FAKE_PG_LSN:-0/16B3740}"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_open* ]]; then
  generation=$((generation + 1))
  ready=false; completed=0; drift=0; error=0
  last_result=; last_drift=-1; zero_drift=false
  expected=0; terminal=0; sealed=false; unresolved=0
  persist
  echo "$generation"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_set_campaign_expected* ]]; then
  expected="$(printf '%s' "$sql" | sed -n "s/.*,\s*\([0-9][0-9]*\)).*/\1/p" | head -n1)"
  expected="${expected:-0}"
  terminal=0
  sealed=false
  ready=false
  zero_drift=false
  persist
  echo "t"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_seal_campaign* ]]; then
  want="$(printf '%s' "$sql" | sed -n "s/.*,\s*\([0-9][0-9]*\)).*/\1/p" | head -n1)"
  want="${want:-0}"
  if [[ "$want" != "$expected" ]]; then
    echo "seal expected mismatch" >&2
    exit 1
  fi
  sealed=true
  ready=false
  zero_drift=false
  persist
  echo "t"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_record_reconcile* ]]; then
  result="success"
  [[ "$sql" == *"'drift'"* ]] && result="drift"
  [[ "$sql" == *"'error'"* ]] && result="error"
  [[ "$sql" == *"'success'"* ]] && result="success"
  dtotal="$(printf '%s' "$sql" | sed -n "s/.*'\\(success\\|drift\\|error\\)',\\([0-9][0-9]*\\),.*/\\2/p" | head -n1)"
  dtotal="${dtotal:-0}"
  completed=$((completed + 1))
  terminal=$((terminal + 1))
  last_result="$result"
  last_drift="$dtotal"
  if [[ "$result" == "drift" || "$dtotal" -gt 0 ]]; then
    drift=$((drift + 1))
    unresolved="$dtotal"
    if [[ "$unresolved" -lt 1 ]]; then unresolved=1; fi
  fi
  if [[ "$result" == "success" && "$dtotal" -eq 0 ]]; then
    unresolved=0
  fi
  if [[ "$result" == "error" ]]; then
    error=$((error + 1))
  fi
  ready=false
  zero_drift=false
  persist
  echo "f"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_try_ready* ]]; then
  if [[ "$generation" -le 0 || "$sealed" != "true" ]]; then
    ready=false; zero_drift=false; persist; echo "f"; exit 0
  fi
  if [[ "$expected" -gt 0 && "$expected" -ne "$terminal" ]]; then
    ready=false; zero_drift=false; persist; echo "f"; exit 0
  fi
  if [[ "$unresolved" -gt 0 || "$error" -gt 0 || "$last_drift" -gt 0 ]]; then
    ready=false; zero_drift=false; persist; echo "f"; exit 0
  fi
  if [[ "$expected" -eq 0 ]]; then
    if [[ "$last_result" != "success" || "$last_drift" != "0" ]]; then
      ready=false; zero_drift=false; persist; echo "f"; exit 0
    fi
  elif [[ "$last_result" != "success" ]]; then
    ready=false; zero_drift=false; persist; echo "f"; exit 0
  fi
  ready=true
  zero_drift=true
  persist
  echo "t"
  exit 0
fi

if [[ "$sql" == *markhand_document_count* ]]; then
  echo "${MARKHAND_FAKE_DOCUMENT_COUNT:-0}"
  exit 0
fi

if [[ "$sql" == *markhand_pending_reconcile_jobs* ]]; then
  echo "${MARKHAND_FAKE_PENDING_JOBS:-0}"
  exit 0
fi

echo "OK"
exit 0

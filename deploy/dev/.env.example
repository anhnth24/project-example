# Local development — copy via: deploy/scripts/init-dev-env.sh
# Never commit deploy/dev/.env (gitignored). Dev-only credentials below.
#
# Default embedding: AITeamVN CPU (Compose profile aiteamvn). Fast CI/mock: COMPOSE_PROFILES=mock

COMPOSE_PROFILES=aiteamvn

MARKHAND_PROFILE=dev
MARKHAND_BIND_ADDR=127.0.0.1:8787
MARKHAND_DATABASE_URL=postgres://markhand_app:markhand_app_dev_only@127.0.0.1:54329/markhand
MARKHAND_QDRANT_URL=http://127.0.0.1:6333
MARKHAND_MINIO_URL=http://127.0.0.1:9000
MARKHAND_MINIO_ACCESS_KEY=markhand
MARKHAND_MINIO_SECRET_KEY=markhand_dev_only

# --- Dev auth (API process only; do NOT set on workers) ---
MARKHAND_AUTH_ISSUER=http://127.0.0.1:8787
MARKHAND_AUTH_AUDIENCE=markhand-dev
MARKHAND_AUTH_SIGNING_KEY=dev-only-signing-key-at-least-32-bytes
MARKHAND_AUTH_KID=dev-key-1

# --- AITeamVN CPU embedding (Compose embedding-cpu :8088, same path as on-prem CPU prod) ---
MARKHAND_EMBEDDING_PORT=8088
MARKHAND_EMBEDDING_BASE_URL=http://127.0.0.1:8088/v1
MARKHAND_EMBEDDING_API_KEY=dev-embedding-key
MARKHAND_EMBEDDING_PROVIDER=openai-compatible
MARKHAND_EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
MARKHAND_EMBEDDING_REVISION=dea33aa1ab339f38d66ae0a40e6c40e0a9249568
MARKHAND_EMBEDDING_DIMENSIONS=1024
MARKHAND_EMBEDDING_MAX_SEQ_LENGTH=2048
MARKHAND_EMBEDDING_BATCH_SIZE=16
MARKHAND_EMBEDDING_RUNTIME_PATH=local-neural
MARKHAND_INDEX_SIGNATURE=ca03085c08f4c01d391ac973192815c944892f6e74b52e7bf4e1f135f65ae97c

# POC upload policy defaults (Phase 0)
MARKHAND_MAX_UPLOAD_BYTES=209715200
MARKHAND_JOB_LEASE_SECONDS=60

# Local-only Compose credentials and host ports. Never reuse in prod.
MARKHAND_POSTGRES_DB=markhand
MARKHAND_POSTGRES_USER=markhand
MARKHAND_POSTGRES_PASSWORD=markhand_dev_only
MARKHAND_MINIO_USER=markhand
MARKHAND_MINIO_PASSWORD=markhand_dev_only

# Fast stub for CI / pipeline-only smoke: COMPOSE_PROFILES=mock and uncomment:
# MARKHAND_EMBEDDING_MODEL=markhand-mock
# MARKHAND_EMBEDDING_REVISION=dev-local
# MARKHAND_EMBEDDING_DIMENSIONS=8
# MARKHAND_EMBEDDING_API_KEY=dev-mock-key
# MARKHAND_INDEX_SIGNATURE=0f59a26d542340c3c2c062a227417e47f9303c2db67569cf9031fe4707e44bf0
# MARKHAND_MOCK_EMBEDDING_DIMENSIONS=8

# Optional GPU profile (docker compose --profile gpu). Not started by default.
# MARKHAND_VLLM_MODEL=markhand-set-a-model
# MARKHAND_VLLM_PORT=8000
# MARKHAND_DEV_PASSWORD=markhand-dev

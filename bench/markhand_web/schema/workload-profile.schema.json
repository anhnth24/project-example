{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "profileId", "status", "approver", "openDecisions", "scale", "loads", "workloads", "serviceTargets", "hardware"],
  "properties": {
    "version": {"const": 1},
    "profileId": {"type": "string", "minLength": 1},
    "status": {"enum": ["proposed", "approved"]},
    "approver": {"type": "string", "minLength": 1},
    "approvedAt": {"type": ["string", "null"]},
    "openDecisions": {"type": "array"},
    "scale": {"type": "object"},
    "loads": {
      "type": "object",
      "required": ["normal", "peak", "recovery", "aggregate"]
    },
    "workloads": {
      "type": "object",
      "required": ["ingest", "query", "recovery"]
    },
    "serviceTargets": {
      "type": "object",
      "required": [
        "bestModelNdcgGapMax", "filteredQueryP99Ms", "rpoMinutes",
        "queryReadyRtoMinutes", "fullVectorRtoMinutes"
      ]
    },
    "hardware": {
      "type": "object",
      "required": ["environmentId", "headroomPercent"]
    }
  }
}

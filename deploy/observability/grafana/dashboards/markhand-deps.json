  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Dependency probe success",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{dependency=~\"$dependency\"}",
          "legendFormat": "{{dependency}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Embedding / retrieval error ratios",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "markhand:embedding:error_ratio_10m",
          "legendFormat": "embedding",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "markhand:retrieval:error_ratio_10m",
          "legendFormat": "retrieval",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Retrieval rate by leg/result",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (leg, result) (rate(markhand_retrieval_total{leg=~\"$leg\"}[5m]))",
          "legendFormat": "{{leg}}/{{result}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Embedding duration",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(markhand_embedding_duration_seconds_sum[5m]) / clamp_min(rate(markhand_embedding_duration_seconds_count[5m]), 1e-9)",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }

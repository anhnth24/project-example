{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MarkhandDocumentsBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::markhand-documents"
      ]
    },
    {
      "Sid": "MarkhandDocumentsObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::markhand-documents/quarantine/*",
        "arn:aws:s3:::markhand-documents/trusted/*"
      ]
    }
  ]
}

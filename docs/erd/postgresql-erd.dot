    </TABLE>
  >];

  // Enforced foreign keys. Parent is on the tee end; child is on the crow end.
  orgs:id -> org_memberships:org_id;
  users:id -> org_memberships:user_id;
  orgs:id -> roles:org_id;
  orgs:id -> role_permissions:org_id;
  roles:id -> role_permissions:role_id;
  permissions:id -> role_permissions:permission_id;

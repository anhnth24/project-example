{
  "uid": "markhand-phase1b",
  "title": "Markhand Phase 1B SLO",
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "tags": ["markhand", "phase-1b"],
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API request latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(markhand_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Job queue depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "markhand_job_queue_depth",
          "legendFormat": "{{job_type}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Job queue age seconds",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "markhand_job_queue_age_seconds",
          "legendFormat": "{{job_type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Conversion / embedding failure ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(markhand_conversion_duration_seconds_count{outcome=~\"failed|error\"}[5m])) / clamp_min(sum(rate(markhand_conversion_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "convert"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(markhand_embedding_batch_duration_seconds_count{outcome=~\"failed|error\"}[5m])) / clamp_min(sum(rate(markhand_embedding_batch_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "embed"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reconcile drift",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(markhand_reconcile_drift_total[30m])",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Quota reservations exceeded",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(markhand_quota_reservation_total{outcome=\"exceeded\"}[15m])",
          "legendFormat": "exceeded"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Backup age seconds",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "markhand_backup_age_seconds",
          "legendFormat": "{{store}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Provider / dependency health",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "up{job=\"markhand-api\"}",
          "legendFormat": "up_{{job}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "probe_success{job=~\"markhand-(postgres|qdrant|minio|embedding)\"}",
          "legendFormat": "probe_{{job}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(markhand_provider_duration_seconds_count{outcome=\"error\"}[5m])) by (provider) / clamp_min(sum(rate(markhand_provider_duration_seconds_count[5m])) by (provider), 1e-9)",
          "legendFormat": "provider_error_{{provider}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk free ratio (node_exporter)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\",mountpoint=~\"/|/var|/data|/workspace\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\",mountpoint=~\"/|/var|/data|/workspace\"}",
          "legendFormat": "{{instance}}:{{device}}:{{mountpoint}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Metrics exporter build",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "markhand_metrics_build",
          "legendFormat": "{{component}}"
        }
      ]
    }
  ]
}

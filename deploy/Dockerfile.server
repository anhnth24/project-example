# Markhand Web API image (fileconv-server).
# Build from repository root:
#   docker build -f deploy/Dockerfile.server -t markhand-api:poc .
#
# No whisper/PhoWhisper models are bundled. Runtime profile stays lean (API only).

FROM rust:1.88.0-bookworm@sha256:af306cfa71d987911a781c37b59d7d67d934f49684058f96cf72079c3626bfe0 AS builder

WORKDIR /src

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY . .

RUN cargo build --release -p fileconv-server --bin fileconv-server \
    && strip /src/target/release/fileconv-server

FROM debian:bookworm-slim@sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818 AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 10001 markhand \
    && useradd --system --uid 10001 --gid markhand \
        --home-dir /var/lib/markhand --create-home markhand

COPY --from=builder /src/target/release/fileconv-server /usr/local/bin/fileconv-server

USER markhand:markhand
WORKDIR /var/lib/markhand

EXPOSE 8787

ENTRYPOINT ["/usr/local/bin/fileconv-server"]

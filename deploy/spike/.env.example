# Disposable benchmark-spike settings. Copy to .env for local overrides.
MARKHAND_COMPOSE_PROJECT=markhand-spike
MARKHAND_SPIKE_VOLUME_PREFIX=markhand-spike

MARKHAND_POSTGRES_DB=markhand_spike
MARKHAND_POSTGRES_USER=markhand
MARKHAND_POSTGRES_PASSWORD=markhand_spike_only
MARKHAND_MINIO_USER=markhand
MARKHAND_MINIO_PASSWORD=markhand_spike_only

MARKHAND_SPIKE_POSTGRES_PORT=15432
MARKHAND_SPIKE_QDRANT_HTTP_PORT=16333
MARKHAND_SPIKE_QDRANT_GRPC_PORT=16334
MARKHAND_SPIKE_MINIO_API_PORT=19000
MARKHAND_SPIKE_MINIO_CONSOLE_PORT=19001
MARKHAND_SPIKE_OTEL_HEALTH_PORT=13143
MARKHAND_SPIKE_OTEL_GRPC_PORT=14317
MARKHAND_SPIKE_MOCK_EMBEDDING_PORT=18088
MARKHAND_SPIKE_VLLM_PORT=18000

# CPU smoke is default. GPU runs require explicit SPIKE_GPU=1 plus runtime model env.
MARKHAND_SPIKE_GPU_COUNT=1
MARKHAND_SPIKE_MOCK_DIMENSIONS=1024
MARKHAND_SPIKE_NESTED=0
MARKHAND_SPIKE_IOPS_VERIFIED=0

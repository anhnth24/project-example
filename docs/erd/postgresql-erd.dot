  jobs:id -> outbox_events:job_id;
  orgs:id -> event_log:org_id;
  jobs:id -> event_log:job_id;
  documents:id -> event_log:document_id;
  document_versions:id -> event_log:version_id;

  orgs:id -> org_quotas:org_id;

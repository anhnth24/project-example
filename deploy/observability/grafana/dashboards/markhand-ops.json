    {
      "id": 1,
      "type": "timeseries",
      "title": "Disk free ratio",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "markhand:disk:free_ratio{mountpoint=~\"$mountpoint\"}",
          "legendFormat": "{{mountpoint}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },

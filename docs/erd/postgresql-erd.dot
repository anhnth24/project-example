  document_versions:id -> embedding_batches:version_id;
  orgs:id -> vector_cleanup_intents:org_id;
  documents:id -> vector_cleanup_intents:document_id;
  jobs:id -> vector_cleanup_intents:job_id;

  orgs:id -> jobs:org_id;

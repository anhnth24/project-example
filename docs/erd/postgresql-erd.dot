digraph markhand_postgresql {
  graph [
    label="Markhand Web — PostgreSQL (migrations 0001–0028)",
    labelloc=t,
    fontsize=22,
    fontname="DejaVu Sans",
    bgcolor="white",
    rankdir=TB,
    newrank=true,
    compound=true,
    splines=polyline,
    nodesep=0.20,
    ranksep=0.85,
    pad=0.25,
    charset="UTF-8"
  ];
  node [shape=plain, fontname="DejaVu Sans", fontsize=9];
  edge [
    color="#667085",
    penwidth=0.9,
    arrowsize=0.7,
    dir=both,
    arrowtail=tee,
    arrowhead=crow,
    fontname="DejaVu Sans",
    fontsize=7
  ];

  subgraph cluster_identity {
    label="Danh tính, xác thực và RBAC";
    color="#93B4D7";
    style="rounded,filled";
    fillcolor="#F5F9FD";
    fontname="DejaVu Sans";
    fontsize=14;

    orgs [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>orgs</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Tổ chức thuê bao của hệ thống</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">slug</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    users [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>users</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Tài khoản người dùng toàn hệ thống</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">display_name</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">disabled_at</TD><TD ALIGN="LEFT">timestamptz ?</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">password_hash</TD><TD ALIGN="LEFT">text ?</TD></TR>
      </TABLE>
    >];

    org_memberships [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>org_memberships</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Thành viên và vai trò cơ bản trong tổ chức</I></TD></TR>
        <TR><TD PORT="org_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="user_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    permissions [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>permissions</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Danh mục quyền thao tác chuẩn</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">code</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    roles [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>roles</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Vai trò RBAC theo tổ chức</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="org_id"><B>FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">code</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">is_system</TD><TD ALIGN="LEFT">boolean</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    role_permissions [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>role_permissions</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Gán quyền cho vai trò RBAC</I></TD></TR>
        <TR><TD PORT="org_id"><B>FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="role_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">role_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="permission_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">permission_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    groups [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>groups</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Nhóm người dùng theo tổ chức</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="org_id"><B>FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text ?</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    group_memberships [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>group_memberships</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Gán người dùng vào nhóm</I></TD></TR>
        <TR><TD PORT="org_id"><B>FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="group_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="user_id"><B>PK/FK</B></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];

    refresh_tokens [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#7397BD">
        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>refresh_tokens</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Phiên đăng nhập bằng refresh token</I></TD></TR>
        <TR><TD PORT="id"><B>PK</B></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="org_id"><B>FK</B></TD><TD ALIGN="LEFT">org_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD PORT="user_id"><B>FK</B></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">family_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">token_hash</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">expires_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">revoked_at</TD><TD ALIGN="LEFT">timestamptz ?</TD></TR>
        <TR><TD PORT="replaced_by_id"><B>FK</B></TD><TD ALIGN="LEFT">replaced_by_id</TD><TD ALIGN="LEFT">uuid ?</TD></TR>

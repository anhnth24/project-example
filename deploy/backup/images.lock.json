{
  "version": 1,
  "platform": "linux/amd64",
  "note": "Pins for backup/restore tooling aligned with deploy/poc/images.lock.json. Scripts invoke host or container CLIs; digests must match POC stack.",
  "images": {
    "postgres": "postgres:18.4-bookworm@sha256:1961f96e6029a02c3812d7cb329a3b03a3ac2bb067058dec17b0f5596aca9296",
    "qdrant": "qdrant/qdrant:v1.18.2@sha256:75eab8c4ba42096724fdcfde8b4de0b5713d529dde32f285a1f86fdcb2c9e50c",
    "minio": "pgsty/minio:RELEASE.2026-06-18T00-00-00Z@sha256:dacff8306a6e0a734518533992dbdcca26bc1ca47f77cf47cb9945725f92b29b",
    "minio-mc": "minio/mc:RELEASE.2025-08-13T08-35-41Z@sha256:a7fe349ef4bd8521fb8497f55c6042871b2ae640607cf99d9bede5e9bdf11727"
  },
  "tools": {
    "openssl": {
      "note": "Host OpenSSL 3.x aes-256-ctr for encrypt-then-MAC envelopes (aes-256-ctr-hmac-sha256-v1); HKDF/HMAC via Python stdlib. No cryptography package."
    },
    "pg_basebackup": {
      "note": "PostgreSQL 16+/18 client matching server major when possible."
    }
  },
  "schema": {
    "recoveryManifestSchemaVersion": 1,
    "path": "deploy/backup/schema/recovery-manifest.schema.json",
    "enforcedBy": "deploy/backup/lib/manifest.py + schema_validate.py"
  },
  "postgresBackup": {
    "method": "pg_basebackup_streamed_wal",
    "continuousPitr": "blocked_unless_archive_wal_packaged_and_consumed",
    "walArchiveOverlay": "preparatory_only"
  },
  "encryption": {
    "algorithm": "aes-256-ctr-hmac-sha256-v1",
    "kdf": "hkdf-sha256",
    "mac": "hmac-sha256",
    "cipher": "openssl enc -aes-256-ctr"
  }
}

# Markhand Web POC stack — copy to deploy/.env (gitignored).
# Never commit real secrets. Values below are disposable POC placeholders.
#
# Boot:
#   cp deploy/.env.example deploy/.env
#   deploy/scripts/poc-up.sh
#   deploy/scripts/poc-health.sh
#
# Index signatures are generated with deploy/scripts/print-index-signature.py
# (see deploy/poc/images.lock.json). Wrong signatures fail embedding/index workers.

COMPOSE_PROFILES=mock
MARKHAND_COMPOSE_PROJECT=markhand-poc

# --- Images (built by compose) ---
MARKHAND_API_IMAGE=markhand-api:poc
MARKHAND_WORKER_IMAGE=markhand-worker:poc
MARKHAND_EMBEDDING_IMAGE=markhand-embedding-cpu:poc

# --- Host-published ports (loopback only) ---
MARKHAND_API_PORT=8788
MARKHAND_POSTGRES_PORT=54330
MARKHAND_QDRANT_HTTP_PORT=6343
MARKHAND_QDRANT_GRPC_PORT=6344
MARKHAND_MINIO_API_PORT=9010
MARKHAND_MINIO_CONSOLE_PORT=9011
MARKHAND_EMBEDDING_PORT=8090

# --- Runtime profile ---
# POC uses `dev` so internal HTTP to Postgres/Qdrant/MinIO is allowed.
# Production TLS termination is out of scope for F02.
MARKHAND_PROFILE=dev

# --- Postgres ---
MARKHAND_POSTGRES_DB=markhand
MARKHAND_POSTGRES_USER=markhand
MARKHAND_POSTGRES_PASSWORD=markhand_poc_change_me
MARKHAND_APP_DB_USER=markhand_app
MARKHAND_APP_DB_PASSWORD=markhand_app_poc_change_me

# --- MinIO ---
# Root credentials are only for minio-init. App/workers use the narrow key.
MARKHAND_MINIO_ROOT_USER=markhand_root
MARKHAND_MINIO_ROOT_PASSWORD=markhand_root_poc_change_me
MARKHAND_MINIO_ACCESS_KEY=markhand_app
MARKHAND_MINIO_SECRET_KEY=markhand_app_poc_change_me
MARKHAND_MINIO_BUCKET=markhand-documents

# --- API auth (API container only; workers must not receive these) ---
MARKHAND_AUTH_ISSUER=http://127.0.0.1:8788
MARKHAND_AUTH_AUDIENCE=markhand-poc
MARKHAND_AUTH_SIGNING_KEY=poc-only-signing-key-at-least-32-bytes
MARKHAND_AUTH_KID=poc-key-1

# --- Mock embedding (COMPOSE_PROFILES=mock) ---
# Signature:
#   python deploy/scripts/print-index-signature.py \
#     --base-url http://mock-embedding:8080/v1 \
#     --model markhand-mock --revision poc-local --dimensions 8
MARKHAND_EMBEDDING_BASE_URL=http://mock-embedding:8080/v1
MARKHAND_EMBEDDING_API_KEY=poc-embedding-key
MARKHAND_EMBEDDING_PROVIDER=openai-compatible
MARKHAND_EMBEDDING_MODEL=markhand-mock
MARKHAND_EMBEDDING_REVISION=poc-local
MARKHAND_EMBEDDING_DIMENSIONS=8
MARKHAND_EMBEDDING_RUNTIME_PATH=local-neural
MARKHAND_INDEX_SIGNATURE=72dda20007ffb7fbe293612091103321eb9e4e0e4a0517a5f3413e31a2978874
MARKHAND_MOCK_EMBEDDING_DIMENSIONS=8

# --- AITeamVN CPU (COMPOSE_PROFILES=aiteamvn) — replace mock block above with: ---
# MARKHAND_EMBEDDING_BASE_URL=http://embedding-cpu:8080/v1
# MARKHAND_EMBEDDING_API_KEY=poc-embedding-key
# MARKHAND_EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
# MARKHAND_EMBEDDING_REVISION=dea33aa1ab339f38d66ae0a40e6c40e0a9249568
# MARKHAND_EMBEDDING_DIMENSIONS=1024
# MARKHAND_EMBEDDING_MAX_SEQ_LENGTH=2048
# MARKHAND_EMBEDDING_BATCH_SIZE=16
# MARKHAND_INDEX_SIGNATURE=dc6f6af4922063ae815fa3c84e17491b059d7c323fb8320d827f34386a038f86
# Signature:
#   python deploy/scripts/print-index-signature.py \
#     --base-url http://embedding-cpu:8080/v1 \
#     --model AITeamVN/Vietnamese_Embedding \
#     --revision dea33aa1ab339f38d66ae0a40e6c40e0a9249568 --dimensions 1024

# --- Worker tenant context (seed org; F03 seed scripts align with these UUIDs) ---
MARKHAND_WORKER_ORG_ID=11111111-1111-1111-1111-111111111111
MARKHAND_WORKER_USER_ID=22222222-2222-2222-2222-222222222201

# --- Upload / job limits (Phase 0 policy) ---
MARKHAND_MAX_UPLOAD_BYTES=209715200
MARKHAND_JOB_LEASE_SECONDS=60
MARKHAND_CONVERTER_TIMEOUT_SECS=120
MARKHAND_CONVERTER_MEMORY_BYTES=536870912

# --- Resource limits (compose) ---
MARKHAND_API_MEM_LIMIT=512m
MARKHAND_API_CPUS=1.0
MARKHAND_API_PIDS_LIMIT=256
MARKHAND_WORKER_MEM_LIMIT=768m
MARKHAND_WORKER_CPUS=1.0
MARKHAND_WORKER_PIDS_LIMIT=512

# License note: PhoWhisper and other unresolved-license models are NOT bundled
# in Dockerfile.worker. Do not copy excluded audio model blobs into images.

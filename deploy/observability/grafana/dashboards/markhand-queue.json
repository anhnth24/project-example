{
  "uid": "markhand-queue",
  "title": "Markhand Queue",
  "tags": [
    "markhand",
    "queue",
    "p1b-o02"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "queue",
        "label": "Queue",
        "type": "custom",
        "query": "convert,embed,index,reconcile,delete",
        "current": {
          "selected": true,
          "text": "convert",
          "value": "convert"
        },
        "options": [
          {
            "selected": true,
            "text": "convert",
            "value": "convert"
          },
          {
            "selected": false,
            "text": "embed",
            "value": "embed"
          },
          {
            "selected": false,
            "text": "index",
            "value": "index"
          },
          {
            "selected": false,
            "text": "reconcile",
            "value": "reconcile"
          },
          {
            "selected": false,
            "text": "delete",
            "value": "delete"
          }
        ],
        "multi": true,
        "includeAll": true,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue depth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "markhand_queue_depth{queue=~\"$queue\"}",
          "legendFormat": "{{queue}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Oldest age seconds",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "markhand_queue_oldest_age_seconds{queue=~\"$queue\"}",
          "legendFormat": "{{queue}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Dead-letter increase (5m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "markhand:job:dead_letter_increase_5m",
          "legendFormat": "{{job_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Job transitions rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "markhand-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job_type, result) (rate(markhand_job_transitions_total[5m]))",
          "legendFormat": "{{job_type}}/{{result}}",
          "datasource": {
            "type": "prometheus",
            "uid": "markhand-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": false,
  "graphTooltip": 1,
  "links": []
}

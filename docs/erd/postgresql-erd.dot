        <TR><TD></TD><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">token_hash</TD><TD ALIGN="LEFT">text</TD></TR>
        <TR><TD PORT="invited_by_user_id"><B>FK</B></TD><TD ALIGN="LEFT">invited_by_user_id</TD><TD ALIGN="LEFT">uuid</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">expires_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">accepted_at</TD><TD ALIGN="LEFT">timestamptz ?</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">revoked_at</TD><TD ALIGN="LEFT">timestamptz ?</TD></TR>
        <TR><TD></TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
      </TABLE>
    >];
  }

  subgraph cluster_acl {
    label="Bộ sưu tập và ACL";

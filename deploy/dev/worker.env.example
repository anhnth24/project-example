# Worker env — copy via: deploy/scripts/init-dev-env.sh → deploy/dev/worker.env
# Load order:
#   set -a && source deploy/dev/.env && set +a
#   set -a && source deploy/dev/worker.env && set +a
# Workers must NOT receive MARKHAND_AUTH_*.

MARKHAND_WORKER_ORG_ID=11111111-1111-1111-1111-111111111111
MARKHAND_WORKER_USER_ID=22222222-2222-2222-2222-222222222201

# AITeamVN CPU (must match deploy/dev/.env)
MARKHAND_EMBEDDING_BASE_URL=http://127.0.0.1:8088/v1
MARKHAND_EMBEDDING_API_KEY=dev-embedding-key
MARKHAND_EMBEDDING_PROVIDER=openai-compatible
MARKHAND_EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
MARKHAND_EMBEDDING_REVISION=dea33aa1ab339f38d66ae0a40e6c40e0a9249568
MARKHAND_EMBEDDING_DIMENSIONS=1024
MARKHAND_EMBEDDING_RUNTIME_PATH=local-neural
MARKHAND_INDEX_SIGNATURE=ca03085c08f4c01d391ac973192815c944892f6e74b52e7bf4e1f135f65ae97c

# Uncomment one worker kind per process (defaults to convert when unset).
# MARKHAND_WORKER_KIND=convert
# MARKHAND_WORKER_ID=dev-convert-1
# MARKHAND_CONVERTER_ARGV_JSON='["./target/release/fileconv","one","{input}"]'


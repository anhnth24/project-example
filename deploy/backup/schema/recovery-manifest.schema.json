{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://markhand.local/schemas/recovery-manifest.schema.json",
  "title": "Markhand recovery manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "createdAt",
    "orgId",
    "appVersion",
    "migrationVersion",
    "indexSignatureSha256",
    "schemaName",
    "consistencyFence",
    "postgres",
    "minio",
    "qdrant",
    "artifacts",
    "checksums",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "manifestId": { "type": "string", "minLength": 8 },
    "createdAt": { "type": "string", "minLength": 20 },
    "orgId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "appVersion": { "type": "string", "minLength": 1 },
    "migrationVersion": { "type": "string", "minLength": 1 },
    "indexSignatureSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "schemaName": { "type": "string", "minLength": 1 },
    "consistencyFence": { "$ref": "#/definitions/consistencyFence" },
    "postgres": { "$ref": "#/definitions/postgres" },
    "minio": { "$ref": "#/definitions/minio" },
    "qdrant": { "$ref": "#/definitions/qdrant" },
    "artifacts": { "$ref": "#/definitions/artifacts" },
    "checksums": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "signature": { "$ref": "#/definitions/signature" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "lsn": { "type": "string", "pattern": "^[0-9A-F]+/[0-9A-F]+$" },
    "encryptionObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "keyId",
        "kdf",
        "saltHex",
        "ivHex",
        "macHex",
        "aad",
        "plaintextSha256",
        "ciphertextSha256"
      ],
      "properties": {
        "algorithm": { "type": "string", "const": "aes-256-ctr-hmac-sha256-v1" },
        "keyId": { "type": "string", "minLength": 1 },
        "kdf": { "type": "string", "const": "hkdf-sha256" },
        "saltHex": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "ivHex": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
        "macHex": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "aad": { "type": "string", "minLength": 1 },
        "plaintextSha256": { "$ref": "#/definitions/sha256" },
        "ciphertextSha256": { "$ref": "#/definitions/sha256" }
      }
    },
    "consistencyFence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "writesFenced",
        "fenceStartedAt",
        "fenceCompletedAt",
        "ordering",
        "boundedInconsistencyNotes",
        "services"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["ordered-bounded", "strict-write-fence"]
        },
        "writesFenced": { "type": "boolean" },
        "fenceStartedAt": { "type": "string", "minLength": 20 },
        "fenceCompletedAt": { "type": "string", "minLength": 20 },
        "ordering": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "string",
            "enum": ["postgres", "minio", "qdrant", "manifest"]
          }
        },
        "boundedInconsistencyNotes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "services": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "postgres": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backupId",
        "method",
        "continuousPitr",
        "timelineId",
        "startWalLsn",
        "stopWalLsn",
        "walBoundaryLsn",
        "baseBackupDigestSha256",
        "walTarDigestSha256",
        "encrypted",
        "encryption",
        "walEncryption",
        "recovery",
        "archiveWalPackaged",
        "archiveWalRequiredThroughLsn"
      ],
      "properties": {
        "backupId": { "type": "string", "minLength": 1 },
        "method": {
          "type": "string",
          "enum": ["pg_basebackup_streamed_wal", "pitr_archive"]
        },
        "continuousPitr": { "type": "boolean" },
        "timelineId": { "type": "integer", "minimum": 1 },
        "startWalLsn": { "$ref": "#/definitions/lsn" },
        "stopWalLsn": { "$ref": "#/definitions/lsn" },
        "walBoundaryLsn": { "$ref": "#/definitions/lsn" },
        "baseBackupDigestSha256": { "$ref": "#/definitions/sha256" },
        "walTarDigestSha256": { "$ref": "#/definitions/sha256" },
        "encrypted": { "type": "boolean", "const": true },
        "encryption": { "$ref": "#/definitions/encryptionObject" },
        "walEncryption": { "$ref": "#/definitions/encryptionObject" },
        "recovery": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "note"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["streamed_wal_consistent", "archive_pitr"]
            },
            "note": { "type": "string", "minLength": 1 }
          }
        },
        "archiveWalPackaged": { "type": "boolean" },
        "archiveWalRequiredThroughLsn": {
          "type": ["string", "null"],
          "pattern": "^[0-9A-F]+/[0-9A-F]+$"
        },
        "archiveWalDigestSha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "archiveWalEncryption": {
          "oneOf": [
            { "$ref": "#/definitions/encryptionObject" },
            { "type": "null" }
          ]
        }
      }
    },
    "minio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "versioningEnabled",
        "inventoryDigestSha256",
        "objectVersionCount",
        "capturedAt",
        "inventoryEncryption",
        "retainsSourceVersionIdsOnRestore",
        "restoreOrder"
      ],
      "properties": {
        "bucket": { "type": "string", "minLength": 1 },
        "versioningEnabled": { "type": "boolean", "const": true },
        "inventoryDigestSha256": { "$ref": "#/definitions/sha256" },
        "objectVersionCount": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "minLength": 20 },
        "inventoryEncryption": { "$ref": "#/definitions/encryptionObject" },
        "retainsSourceVersionIdsOnRestore": { "type": "boolean", "const": false },
        "restoreOrder": { "type": "string", "const": "oldest_to_newest" }
      }
    },
    "qdrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotId",
        "collectionName",
        "collectionGeneration",
        "pointsCount",
        "indexSignatureSha256",
        "snapshotDigestSha256",
        "collectionConfig",
        "capturedAt",
        "api"
      ],
      "properties": {
        "snapshotId": { "type": "string", "minLength": 1 },
        "collectionName": {
          "type": "string",
          "pattern": "^markhand_chunks_[a-f0-9]{64}$"
        },
        "collectionGeneration": { "type": "integer", "minimum": 0 },
        "pointsCount": { "type": "integer", "minimum": 0 },
        "indexSignatureSha256": { "$ref": "#/definitions/sha256" },
        "snapshotDigestSha256": { "$ref": "#/definitions/sha256" },
        "collectionConfig": { "type": "object" },
        "capturedAt": { "type": "string", "minLength": 20 },
        "api": {
          "type": "object",
          "additionalProperties": false,
          "required": ["create", "download", "uploadRecover"],
          "properties": {
            "create": { "type": "string", "minLength": 1 },
            "download": { "type": "string", "minLength": 1 },
            "uploadRecover": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePaths"],
      "properties": {
        "relativePaths": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\./)[A-Za-z0-9._/-]+$"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "type": "string", "const": "hmac-sha256" },
        "keyId": { "type": "string", "minLength": 1 },
        "value": { "$ref": "#/definitions/sha256" }
      }
    }
  }
}

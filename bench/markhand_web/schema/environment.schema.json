{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "version", "environmentId", "role", "status", "approver", "cpu", "ramGb",
    "disk", "gpu", "network", "os", "fingerprintRequiredFields"
  ],
  "properties": {
    "version": {"const": 1},
    "environmentId": {"type": "string", "minLength": 1},
    "role": {"enum": ["benchmark-target", "spike", "ci-smoke"]},
    "status": {"enum": ["proposed", "approved"]},
    "approver": {"type": "string", "minLength": 1},
    "fingerprintRequiredFields": {"type": "array", "minItems": 1}
  }
}

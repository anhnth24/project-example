        <TR><TD BGCOLOR="#CFE2F3" COLSPAN="3"><B>org_invites</B></TD></TR>
        <TR><TD BGCOLOR="#EAF3FA" COLSPAN="3"><I>Lời mời tham gia tổ chức</I></TD></TR>

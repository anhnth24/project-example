  "fault": [
    {
      "id": "fault-kill-convert-after-claim",
      "targetService": "worker-convert",
      "phase": "after_claim",
      "expect": "lease_reclaim_idempotent_no_duplicate_version"
    },
    {
      "id": "fault-kill-convert-after-checkpoint",
      "targetService": "worker-convert",
      "phase": "after_checkpoint",
      "expect": "resume_or_retry_consistent"
    },
    {
      "id": "fault-kill-index-after-claim",
      "targetService": "worker-index",
      "phase": "after_claim",
      "expect": "lease_reclaim_no_duplicate_chunks"
    },
    {
      "id": "fault-dependency-outage-bounded",
      "targetService": "qdrant",
      "phase": "during_search",
      "expect": "bounded_5xx_or_warning_no_partial_trusted"
    }
  ],

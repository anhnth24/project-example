#!/usr/bin/env bash
# Hermetic psql: simulates readiness helpers with durable temp state.
set -euo pipefail
if [[ "${MARKHAND_FAKE_PSQL_FAIL:-0}" == "1" ]]; then
  echo "ERROR: fake psql failure" >&2
  exit 1
fi

STATE_DIR="${MARKHAND_FAKE_PSQL_STATE:-${TMPDIR:-/tmp}/markhand-fake-psql-state}"
mkdir -p "$STATE_DIR"
STATE="$STATE_DIR/readiness.state"
if [[ ! -f "$STATE" ]]; then
  cat >"$STATE" <<'EOF'
generation=0
ready=false
completed=0
drift=0
error=0
last_result=
last_drift=-1
zero_drift=false
EOF
fi

# shellcheck disable=SC1090
source "$STATE"

sql=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c)
      sql="$2"
      shift 2
      ;;
    -v)
      shift 2
      ;;
    -At|-A|-t|-q|-X)
      shift
      ;;
    -h|-p|-U|-d)
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

persist() {
  cat >"$STATE" <<EOF
generation=$generation
ready=$ready
completed=$completed
drift=$drift
error=$error
last_result=$last_result
last_drift=$last_drift
zero_drift=$zero_drift
EOF
}

if [[ -z "$sql" ]]; then
  printf '%s\n' "${MARKHAND_FAKE_PG_TIMELINE:-1}"
  printf '%s\n' "${MARKHAND_FAKE_PG_LSN:-0/16B3740}"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_open* ]]; then
  generation=$((generation + 1))
  ready=false
  completed=0
  drift=0
  error=0
  last_result=
  last_drift=-1
  zero_drift=false
  persist
  echo "$generation"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_record_reconcile* ]]; then
  result="success"
  dtotal=0
  [[ "$sql" == *"'drift'"* ]] && result="drift"
  [[ "$sql" == *"'error'"* ]] && result="error"
  [[ "$sql" == *"'success'"* ]] && result="success"
  # Extract drift_total argument (third arg): ...'result',N,'detail'...
  dtotal="$(printf '%s' "$sql" | sed -n "s/.*'\\(success\\|drift\\|error\\)',\\([0-9][0-9]*\\),.*/\\2/p" | head -n1)"
  dtotal="${dtotal:-0}"
  completed=$((completed + 1))
  last_result="$result"
  last_drift="$dtotal"
  if [[ "$result" == "drift" || "$dtotal" -gt 0 ]]; then
    drift=$((drift + 1))
  fi
  if [[ "$result" == "error" ]]; then
    error=$((error + 1))
  fi
  ready=false
  zero_drift=false
  persist
  echo "f"
  exit 0
fi

if [[ "$sql" == *markhand_runtime_readiness_try_ready* ]]; then
  if [[ "$generation" -le 0 || "$drift" -gt 0 || "$error" -gt 0 || "$last_drift" -gt 0 || "$completed" -le 0 || "$last_result" != "success" ]]; then
    ready=false
    zero_drift=false
    persist
    echo "f"
    exit 0
  fi
  ready=true
  zero_drift=true
  persist
  echo "t"
  exit 0
fi

if [[ "$sql" == *markhand_document_count* ]]; then
  echo "${MARKHAND_FAKE_DOCUMENT_COUNT:-0}"
  exit 0
fi

echo "OK"
exit 0

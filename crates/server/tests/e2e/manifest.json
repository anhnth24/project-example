  "security": [
    {
      "id": "sec-user-disabled",
      "class": "authorization",
      "expect": "no_text_401_or_403"
    },
    {
      "id": "sec-user-suspended",
      "class": "authorization",
      "expect": "no_text_401_or_403"
    },
    {
      "id": "sec-membership-removed",
      "class": "authorization",
      "expect": "no_text_401_or_403"
    },
    {
      "id": "sec-collection-acl-revoke",
      "class": "authorization",
      "expect": "no_text_403_or_empty"
    },
    {
      "id": "sec-tombstone-during-query",
      "class": "authorization",
      "expect": "no_text_after_delete"
    },
    {
      "id": "sec-tombstone-during-stream",
      "class": "authorization",
      "expect": "stream_closes_no_text"
    },
    {
      "id": "sec-historical-permission-revoke",
      "class": "authorization",
      "expect": "history_denied"
    },
    {
      "id": "sec-malformed-ids",
      "class": "validation",
      "expect": "stable_4xx"
    },
    {
      "id": "sec-malformed-body",
      "class": "validation",
      "expect": "stable_4xx"
    },
    {
      "id": "sec-malformed-cursors",
      "class": "validation",
      "expect": "stable_4xx"
    },
    {
      "id": "sec-malformed-last-event-id",
      "class": "validation",
      "expect": "stable_4xx"
    },
    {
      "id": "sec-idor-cross-org",
      "class": "idor",
      "expect": "404_or_403_no_leak"
    },
    {
      "id": "sec-prompt-injection-untrusted",
      "class": "prompt",
      "fixtureId": "e2e-adv-prompt-html",
      "expect": "untrusted_or_quarantine_no_tool_leak"
    },
    {
      "id": "sec-zip-bomb",
      "class": "upload_abuse",
      "fixtureId": "e2e-adv-zip-bomb",
      "expect": "reject_or_quarantine"
    },
    {
      "id": "sec-path-traversal",
      "class": "upload_abuse",
      "fixtureId": "e2e-adv-traversal",
      "expect": "reject_or_quarantine"
    },
    {
      "id": "sec-extension-spoof",
      "class": "upload_abuse",
      "fixtureId": "e2e-adv-spoof-pdf",
      "expect": "reject"
    },
    {
      "id": "sec-oversize",
      "class": "upload_abuse",
      "expect": "reject_413_or_400"
    },
    {
      "id": "sec-malformed-format",
      "class": "upload_abuse",
      "fixtureId": "e2e-adv-malformed-docx",
      "expect": "reject_or_quarantine"

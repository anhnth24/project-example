  subgraph cluster_retrieval {
    label="Lập chỉ mục, truy hồi và tri thức";
    color="#A88AC4";
    style="rounded,filled";
    fillcolor="#FAF6FD";
    fontname="DejaVu Sans";
    fontsize=14;

    index_metadata [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#8D70AA">
